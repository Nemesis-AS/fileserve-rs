STORAGE_PATH=/path/to/storage
JWT_SECRET=jwt_secret
TUS_MAX_SIZE=5368709120
# Default storage quota (GB) for new users when none is specified.
# Optional — the config layer falls back to 20 when unset.
# DEFAULT_QUOTA_GB=20

# Comma-separated origins allowed to make credentialed cross-origin requests.
# Optional — defaults to the Vite dev-server origins. The frontend is served
# same-origin in production, so set this empty (ALLOWED_ORIGINS=) there to
# disable cross-origin access entirely.
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173